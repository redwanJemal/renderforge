{
  "name": "renderforge",
  "version": "0.1.0",
  "private": true,
  "description": "RenderForge Studio — Content Automation Platform",
  "scripts": {
    "dev:api": "pnpm --filter @renderforge/api dev",
    "dev:admin": "pnpm --filter @renderforge/admin dev",
    "dev:renderer": "pnpm --filter @renderforge/renderer dev",
    "build:api": "pnpm --filter @renderforge/api build",
    "build:admin": "pnpm --filter @renderforge/admin build",
    "build:renderer": "pnpm --filter @renderforge/renderer build",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @renderforge/db generate",
    "db:migrate": "pnpm --filter @renderforge/db migrate",
    "db:push": "pnpm --filter @renderforge/db push",
    "db:seed": "pnpm --filter @renderforge/db seed",
    "db:studio": "pnpm --filter @renderforge/db studio",
    "render": "tsx scripts/render-cli.ts",
    "lint": "eslint src/",
    "typecheck": "pnpm -r typecheck"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@remotion/cli": "4.0.415",
    "@remotion/renderer": "4.0.415",
    "@remotion/transitions": "4.0.415",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "remotion": "4.0.415",
    "zod": "^3.22.0"
  },
  "overrides": {
    "remotion": "4.0.415",
    "@remotion/bundler": "4.0.415",
    "@remotion/renderer": "4.0.415",
    "@remotion/player": "4.0.415",
    "@remotion/media-utils": "4.0.415",
    "@remotion/streaming": "4.0.415",
    "@remotion/studio-server": "4.0.415",
    "@remotion/studio-shared": "4.0.415",
    "@remotion/studio": "4.0.415",
    "@remotion/paths": "4.0.415",
    "@remotion/shapes": "4.0.415",
    "@remotion/transitions": "4.0.415",
    "@remotion/licensing": "4.0.415",
    "@remotion/media-parser": "4.0.415",
    "@remotion/zod-types": "4.0.415",
    "@remotion/webcodecs": "4.0.415",
    "@remotion/web-renderer": "4.0.415",
    "@remotion/compositor-linux-arm64-gnu": "4.0.415"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
